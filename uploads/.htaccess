# Phase 13/14: deny ALL direct access to uploaded files by default. Every
# customer-data fetch must go through one of:
#   /agent/file_download.php?id=N        - generic files (encrypted, audited)
#   /photo.php?type=X&id=N               - photos (ACL'd, MIME-checked)
# Both endpoints authenticate, ACL-check, and audit denials.
#
# Public-by-design assets (favicon, company logo, document inline images)
# are re-granted access — favicon.ico via a <Files> override here, and
# subdirectories settings/ + documents/ via their own .htaccess files.

Options -Indexes -ExecCGI
php_flag engine off
RemoveHandler .php .phtml .phar .phps
RemoveType .php .phtml .phar .phps

# Hard deny any executable / scriptable type as belt-and-braces.
<FilesMatch "\.(php|phtml|phar|phps|cgi|pl|sh|py|rb|asp|aspx|jsp|exe|bat|ps1)$">
  Require all denied
</FilesMatch>

# Default-deny everything.
<FilesMatch ".*">
  Require all denied
</FilesMatch>

# Re-allow the favicon (rendered in <link rel=icon> on every page,
# including pre-auth login / vault unlock — must be fetchable without
# a session). The <Files> override comes after the wildcard deny so
# Apache 2.4 authorization merging picks the more specific rule.
<Files "favicon.ico">
  Require all granted
</Files>
